---
import "../styles/global.css";
import Chip from "./Chip.astro";

type Props = {
  projects: {
    title: string;
    description: string;
    skills: string[];
  }[];
};

const { projects } = Astro.props;
---

<p class="text-4xl text-[#EEEEEE] font-bold w-full border-b border-[#686868]">
  Projects
</p>

<div class="grid grid-cols-2 gap-5 h-full overflow-y-auto">
  {
    projects.map((proj) => (
      <div class="flex flex-col space-y-1 justify-center bg-[#171717] border border-[#EEEEEE] rounded-md py-1 px-3">
        <p class="text-[#EEEEEE] text-lg font-bold capitalize">{proj.title}</p>
        <p class="text-[#686868] font-light">{proj.description}</p>

        <div class="flex flex-wrap gap-2">
          {proj.skills.map((skill) => (
            <Chip text={skill} />
          ))}
        </div>
      </div>
    ))
  }
</div>
