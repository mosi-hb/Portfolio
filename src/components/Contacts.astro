---
import { Icon } from "astro-icon/components";

type Props = {
  contacts: {
    icon: string;
    title: string;
    information: string;
    link: string;
  }[];
};

const { contacts } = Astro.props;
---

<p class="text-4xl text-[#EEEEEE] font-bold w-full border-b border-[#686868]">
  Contacts
</p>

<div class="flex flex-col space-y-5 size-full">
  {
    contacts.map((con) => (
      <a
        href={con.link}
        target="_blank"
        class="flex items-center space-x-3 bg-[#171717] border border-[#EEEEEE] rounded-md p-2 cursor-pointer"
      >
        <div class="flex-none w-10 h-10 p-1 border border-[#EEEEEE] rounded-sm">
          <Icon name={con.icon} class="size-full" />
        </div>
        <div class="text-sm flex-1 overflow-hidden">
          <p class="text-[#686868] font-light">{con.title}</p>
          <p class="text-[#EEEEEE] truncate max-w-full">{con.information}</p>
        </div>
        <div>
          <Icon name="open" />
        </div>
      </a>
    ))
  }
</div>
